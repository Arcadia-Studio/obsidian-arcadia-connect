    if (person.organization) {
      new import_obsidian6.Notice(`${msg} (${person.organization})`, 8e3);
    } else {
      new import_obsidian6.Notice(msg, 8e3);
    }
  }
  showOverdueSummary(overdue) {
    if (overdue.length === 1) {
      this.showFollowUpNotice(overdue[0], true);
    } else {
